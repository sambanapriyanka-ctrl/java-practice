class Car {

    private int speed;

    public void setSpeed(int s) {
        speed = s;
    }

    public int getSpeed() {
        return speed;
    }
}

public class Main {

    public static void main(String[] args) {

        Car car = new Car();

        car.setSpeed(80);

        System.out.println(car.getSpeed());
    }
}
